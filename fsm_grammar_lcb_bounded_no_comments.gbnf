# Richer LiveCodeBench plan with bounded planning lines and no comments/backticks.
# This targets the two observed displacement channels:
#   1. huge one-line GOAL/STATE/ALGO/EDGE/VERIFY fields
#   2. Python-comment scratchpads after </think>
#
# Each rule MUST be on a single line for llama.cpp's GBNF parser.

root ::= think code
think ::= "<think>\n" "GOAL: " line "STATE: " line "ALGO: " line "EDGE: " line "VERIFY: " line "</think>\n\n"
line ::= [^\n]{1,240} "\n"
code ::= [\x09\x0A\x0D\x20-\x22\x24-\x5F\x61-\x7E]+
