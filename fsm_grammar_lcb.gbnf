# Richer structured plan for harder coding tasks such as LiveCodeBench.
# Compared with fsm_grammar.gbnf, this gives the model a few more planning
# slots and forces the answer to be one fenced Python block.
#
# The Python body deliberately excludes backticks and "#" comments.  This
# prevents multiple markdown drafts and discourages scratchpad migration into
# comments after </think>.  It is intentionally stricter than the HumanEval
# grammar and should be evaluated separately.
#
# Each rule MUST be on a single line for llama.cpp's GBNF parser.

root ::= think code
think ::= "<think>\n" "GOAL: " line "STATE: " line "ALGO: " line "EDGE: " line "VERIFY: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= "```python\n" pycode "```"
pycode ::= [\x09\x0A\x0D\x20-\x22\x24-\x5F\x61-\x7E]+
