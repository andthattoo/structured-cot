# Richer LiveCodeBench plan with a single fenced Python answer.
# Compared with fsm_grammar_lcb.gbnf, this allows "#" comments inside code.
# That makes it less brittle if the model spills explanatory text into comments,
# while still preventing multiple markdown/code-fence drafts via backtick ban.
#
# Each rule MUST be on a single line for llama.cpp's GBNF parser.

root ::= think code
think ::= "<think>\n" "GOAL: " line "STATE: " line "ALGO: " line "EDGE: " line "VERIFY: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= "```python\n" pycode "```"
pycode ::= [\x09\x0A\x0D\x20-\x5F\x61-\x7E]+
