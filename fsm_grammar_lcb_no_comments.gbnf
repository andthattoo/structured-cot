# Richer LiveCodeBench plan with comments/backticks blocked in the answer.
# This isolates whether removing the Python-comment scratchpad helps without
# also forcing a markdown code fence.
#
# Each rule MUST be on a single line for llama.cpp's GBNF parser.

root ::= think code
think ::= "<think>\n" "GOAL: " line "STATE: " line "ALGO: " line "EDGE: " line "VERIFY: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= [\x09\x0A\x0D\x20-\x22\x24-\x5F\x61-\x7E]+
