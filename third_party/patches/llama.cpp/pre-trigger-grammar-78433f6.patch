+bool llama_sampler_grammar_is_done(const struct llama_sampler * smpl) {
+    if (!smpl) {
+        return true;
+    }
+    const auto * ctx = (const llama_sampler_grammar *) smpl->ctx;
+    if (!ctx->grammar) {
+        return true;
+    }
+    for (const auto & stack : ctx->grammar->stacks) {
+        if (stack.empty()) {
+            return true;
+        }
+    }
+    return false;
+}
